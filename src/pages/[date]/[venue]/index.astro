---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AIRaceComment from '../../../components/AIRaceComment.astro';
import {
  VENUES,
  getComputerDataUrl,
  getEntriesDataUrl,
  getRacebookDataUrl,
  type ComputerData,
  type ComputerHorse,
  type EntriesData,
  type EntryHorse,
  type RecentRace,
  type RacebookData,
  type RacebookHorse,
} from '../../../lib/venues';

const { date, venue: venueCode } = Astro.params;

if (!date || !/^\d{4}-\d{2}-\d{2}$/.test(date) || !venueCode) {
  return Astro.redirect('/');
}

// OI → OOI へのリダイレクト（後方互換性）
if (venueCode.toUpperCase() === 'OI') {
  return Astro.redirect(`/${date}/OOI`);
}

const venueInfo = VENUES.find(v => v.code === venueCode.toUpperCase());
if (!venueInfo) {
  return Astro.redirect('/');
}

// コンピ指数データ取得
let data: ComputerData | null = null;
let fetchUrl = '';
try {
  fetchUrl = getComputerDataUrl(date, venueInfo);
  const res = await fetch(fetchUrl);
  if (res.ok) {
    data = await res.json();
  }
} catch (_) {}

// 出馬表データ取得
let entriesData: EntriesData | null = null;
try {
  const entriesUrl = getEntriesDataUrl(date, venueInfo);
  const res = await fetch(entriesUrl);
  if (res.ok) {
    entriesData = await res.json();
  }
} catch (_) {}

// racebook データ取得（race-data-importer由来）
let racebookData: RacebookData | null = null;
try {
  const rbUrl = getRacebookDataUrl(date, venueInfo);
  const res = await fetch(rbUrl);
  if (res.ok) {
    racebookData = await res.json();
  }
} catch (_) {}

// racebook馬名→馬データマップ（印・近走・調教）
const racebookHorseMap = new Map<string, RacebookHorse>();
if (racebookData) {
  for (const race of racebookData.races) {
    for (const horse of race.horses) {
      racebookHorseMap.set(`${race.raceNumber}-${horse.number}`, horse);
    }
  }
}

// 出馬表の馬名 → recentRaces マップ（AI解説用）
const horseRecentMap = new Map<string, RecentRace[]>();
if (entriesData) {
  for (const race of entriesData.races) {
    for (const horse of race.horses) {
      if (horse.recentRaces && horse.recentRaces.length > 0) {
        horseRecentMap.set(horse.name, horse.recentRaces);
      }
    }
  }
}

const prev = new Date(date); prev.setDate(prev.getDate() - 1);
const next = new Date(date); next.setDate(next.getDate() + 1);
const fmt = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;

function formatDateJa(d: string): string {
  const [y, m, day] = d.split('-');
  return `${y}年${Number(m)}月${Number(day)}日（${['日','月','火','水','木','金','土'][new Date(d).getDay()]}）`;
}

// 印を付与（指数順で◎○▲△）
function getMark(rank: number): { mark: string; key: string; role: string } {
  if (rank === 0) return { mark: '◎', key: 'honmei', role: '本命' };
  if (rank === 1) return { mark: '○', key: 'taikou', role: '対抗' };
  if (rank === 2) return { mark: '▲', key: 'tanana', role: '単穴' };
  if (rank <= 9)  return { mark: '△', key: 'renshita', role: '連下' };
  return { mark: '', key: 'none', role: '' };
}

// 各レースに印と調整済み指数を付与
interface HorseWithMark extends ComputerHorse {
  mark: string;
  markKey: string;
  displayIndex: number;
  role: string;
}

const races = data?.races.map(race => {
  const sorted = [...race.horses].sort((a, b) => b.computerIndex - a.computerIndex);
  let markRank = 0;
  const horses: HorseWithMark[] = sorted.map((h) => {
    const tempDisplayIndex = h.computerIndex - 10;
    if (tempDisplayIndex <= 34) {
      return { ...h, mark: '', markKey: 'none', displayIndex: h.computerIndex - 11, role: '' };
    }
    const { mark, key, role } = getMark(markRank);
    markRank++;
    const displayIndex = markRank === 1 ? h.computerIndex - 10 : h.computerIndex - 11;
    return { ...h, mark, markKey: key, displayIndex, role };
  });
  const byNumber = [...horses].sort((a, b) => a.number - b.number);
  return { ...race, horses: byNumber };
}) ?? [];

const hasJockey  = races[0]?.horses[0]?.jockey   != null;
const hasTrainer = races[0]?.horses[0]?.trainer  != null;
const hasWeight  = races[0]?.horses[0]?.weight    != null;
const hasAgeGend = races[0]?.horses[0]?.ageGender != null;

// AI解説用データ生成（各レースごと）
function buildAIRaceData(race: typeof races[0], raceIndex: number) {
  const sorted = [...race.horses].sort((a, b) => b.displayIndex - a.displayIndex);
  const topHorses = sorted.filter(h => h.markKey !== 'none').slice(0, 6).map(h => {
    const recentRaces = horseRecentMap.get(h.name) || [];
    return {
      role: h.role,
      horseNumber: h.number,
      horseName: h.name,
      computerIndex: h.displayIndex,
      jockey: h.jockey || '',
      recentRaces: recentRaces.slice(0, 3).map(r => ({
        date: r.date,
        venue: r.venue,
        distance: r.distance,
        finish: r.finish,
        finishStatus: r.finishStatus,
        headCount: r.headCount,
        passingOrder: r.passingOrder,
        last3f: r.last3f,
      })),
    };
  });

  return JSON.stringify({
    venue: venueInfo.name,
    date,
    raceNumber: race.raceNumber,
    raceName: race.raceName || '',
    distance: race.distance,
    horseCount: race.horses.length,
    topHorses,
  });
}

const title = `${venueInfo.name} ${formatDateJa(date)} AI指数`;
---

<BaseLayout title={title} description={`${formatDateJa(date)} ${venueInfo.name}のAI指数`}>
  <!-- パンくず -->
  <nav class="breadcrumb" aria-label="パンくず">
    <a href="/">今日</a>
    <span>›</span>
    <a href={`/${date}`}>{formatDateJa(date)}</a>
    <span>›</span>
    <span class="current">{venueInfo.name}</span>
  </nav>

  <!-- ヘッダー -->
  <header class="venue-hero">
    <div class="venue-hero-inner">
      <div class="venue-hero-left">
        <span class={`cat-pill cat-${venueInfo.category}`}>{venueInfo.categoryLabel}</span>
        <h1 class="venue-title">{venueInfo.name}競馬</h1>
        <p class="venue-date">{formatDateJa(date)}</p>
      </div>
      <div class="venue-hero-nav">
        <a class="nav-btn" href={`/${fmt(prev)}/${venueCode}`}>
          <span class="arrow">‹</span>
          <span class="label">{Number(fmt(prev).split('-')[2])}日</span>
        </a>
        <a class="nav-btn back-btn" href={`/${date}`}>一覧</a>
        <a class="nav-btn" href={`/${fmt(next)}/${venueCode}`}>
          <span class="label">{Number(fmt(next).split('-')[2])}日</span>
          <span class="arrow">›</span>
        </a>
      </div>
    </div>
  </header>

  <!-- メインタブ（指数 / 印・近走 / 出馬表） -->
  <div class="main-tab-bar" id="mainTabBar">
    <button class="main-tab-btn active" data-main-tab="index">コンピ指数</button>
    {racebookData && <button class="main-tab-btn" data-main-tab="racebook">印・近走</button>}
    {entriesData && <button class="main-tab-btn" data-main-tab="entries">出馬表</button>}
  </div>

  <!-- ═══ コンピ指数パネル ═══ -->
  <div class="main-tab-panel active" id="mainPanel-index">
    <!-- 凡例 + ソートトグル -->
    <div class="legend">
      <span class="leg-item honmei">◎ 本命</span>
      <span class="leg-item taikou">○ 対抗</span>
      <span class="leg-item tanana">▲ 単穴</span>
      <span class="leg-item renshita">△ 連下</span>
      <div class="sort-toggle" id="sortToggle">
        <button class="sort-btn active" data-sort="number">馬番順</button>
        <button class="sort-btn" data-sort="index">指数順</button>
      </div>
    </div>

    <!-- 有料誘導バナー（JRA・南関のみ） -->
    {venueInfo.category !== 'local' && (
      <a href="https://keiba-intelligence.jp/pricing" target="_blank" rel="noopener" class="inline-cta">
        <div class="inline-cta-left">
          <span class="inline-cta-label">PRO</span>
          <span class="inline-cta-text">
            <strong>全買い目・PRO分析</strong>はkeiba-intelligence.jpで公開中
          </span>
        </div>
        <span class="inline-cta-arrow">詳細を見る →</span>
      </a>
    )}

    {!data ? (
      <div class="empty-state">
        <div class="empty-icon">📭</div>
        <p>この日の{venueInfo.name}のデータはありません</p>
      </div>
    ) : (
      <div class="tab-container" id="tabContainer">
        <!-- レースタブバー -->
        <div class="tab-bar" role="tablist" id="tabBar">
          {races.map((race, i) => (
            <button
              class={`tab-btn ${i === 0 ? 'active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-tab={i}
              aria-controls={`panel-${i}`}
            >
              {race.raceNumber}R
            </button>
          ))}
        </div>

        <!-- レースタブパネル -->
        {races.map((race, i) => {
          const aiData = buildAIRaceData(race, i);
          return (
            <div
              class={`tab-panel ${i === 0 ? 'active' : ''}`}
              role="tabpanel"
              id={`panel-${i}`}
              data-panel={i}
            >
              <!-- レース情報 -->
              <div class="race-info-bar">
                <span class="race-num-badge">{race.raceNumber}R</span>
                <span class="race-name-text">{race.raceName || '　'}</span>
                {race.distance && <span class="race-chip">{race.surface}{race.distance}m</span>}
                {race.startTime && <span class="race-chip">{race.startTime}発走</span>}
              </div>

              <!-- AI予想解説 -->
              {entriesData && (
                <AIRaceComment raceData={aiData} />
              )}

              <!-- 全頭テーブル -->
              <div class="horse-table-wrap">
                <table class="horse-table">
                  <thead>
                    <tr>
                      <th class="th-mark">印</th>
                      <th class="th-num">馬番</th>
                      <th class="th-name">馬名</th>
                      <th class="th-idx">指数</th>
                      {hasJockey  && <th class="th-small">騎手</th>}
                      {hasTrainer && <th class="th-small">調教師</th>}
                      {hasWeight  && <th class="th-small">斤量</th>}
                      {hasAgeGend && <th class="th-small">馬齢</th>}
                    </tr>
                  </thead>
                  <tbody class="horse-tbody">
                    {race.horses.map(horse => (
                      <tr
                        class={`row-${horse.markKey}`}
                        data-number={horse.number}
                        data-index={horse.computerIndex}
                      >
                        <td class="td-mark">
                          {horse.mark && (
                            <span class={`mark-pill ${horse.markKey}`}>{horse.mark}</span>
                          )}
                        </td>
                        <td class="td-num">{horse.number}</td>
                        <td class="td-name">{horse.name}</td>
                        <td class="td-idx">
                          <span class={`idx-val ${horse.markKey}`}>{horse.displayIndex}</span>
                        </td>
                        {hasJockey  && <td class="td-small">{horse.jockey  ?? '—'}</td>}
                        {hasTrainer && <td class="td-small">{horse.trainer ?? '—'}</td>}
                        {hasWeight  && <td class="td-small">{horse.weight  ?? '—'}</td>}
                        {hasAgeGend && <td class="td-small">{horse.ageGender ?? '—'}</td>}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>

              <!-- keiba-intelligence CTA（JRA・南関のみ） -->
              {venueInfo.category !== 'local' && (
                <a href="https://keiba-intelligence.jp/pricing" target="_blank" rel="noopener" class="race-cta">
                  <span class="race-cta-badge">PRO</span>
                  <span class="race-cta-text">全買い目・PRO分析はこちら</span>
                  <span class="race-cta-arrow">→</span>
                </a>
              )}
            </div>
          );
        })}
      </div>
    )}
  </div>

  <!-- ═══ 印・近走パネル ═══ -->
  {racebookData && (
    <div class="main-tab-panel" id="mainPanel-racebook">
      {racebookData.races.map((race) => {
        const assignMap = {};
        if (race.assignments) {
          if (race.assignments.main) assignMap[race.assignments.main] = '◎';
          if (race.assignments.sub) assignMap[race.assignments.sub] = '○';
          if (race.assignments.hole) assignMap[race.assignments.hole] = '▲';
          if (race.assignments.connectTop) assignMap[race.assignments.connectTop] = '△';
          for (const n of race.assignments.connect) assignMap[n] = '△';
          for (const n of race.assignments.reserve) assignMap[n] = '☆';
        }
        return (
          <div class="rb-race-card">
            <div class="rb-race-header">
              <span class="rb-race-num">{race.raceNumber}R</span>
              <span class="rb-race-name">{race.raceClass}</span>
              <span class="rb-race-dist">{race.distance}</span>
              {race.startTime && <span class="rb-race-time">{race.startTime}発走</span>}
              <span class="rb-race-count">{race.horseCount}頭</span>
            </div>
            <div class="rb-horse-list">
              {race.horses.map((h) => {
                const mark = assignMap[h.number] || '';
                const markCls = mark === '◎' ? 'honmei' : mark === '○' ? 'taikou' : mark === '▲' ? 'tanana' : mark === '△' ? 'renka' : mark === '☆' ? 'hoseki' : '';
                return (
                  <div class={`rb-horse ${markCls ? 'rb-' + markCls : ''}`}>
                    <div class="rb-horse-main">
                      {mark && <span class={`rb-mark rb-mark-${markCls}`}>{mark}</span>}
                      <span class="rb-num">{h.number}</span>
                      <span class="rb-name">{h.name}</span>
                      <span class="rb-info">{h.sexAge} {h.weight ? h.weight + 'kg' : ''} {h.jockey || ''}</span>
                      {h.trainer && <span class="rb-trainer">{h.trainer}</span>}
                      {h.totalScore > 0 && <span class="rb-score">{h.totalScore}点</span>}
                    </div>
                    {h.marks && h.marks.length > 0 && (
                      <div class="rb-marks-row">
                        {h.marks.map((m: string) => <span class="rb-mark-chip">{m}</span>)}
                      </div>
                    )}
                    {h.pastRaces && h.pastRaces.length > 0 && (
                      <div class="rb-past">
                        {h.pastRaces.slice(0, 4).map((pr) => (
                          <span class="rb-past-item">
                            {pr.finish != null ? pr.finish + '着' : '?着'}
                            {pr.venue && <Fragment> {pr.venue}</Fragment>}
                            {pr.distance && <Fragment> {pr.distance}</Fragment>}
                            {pr.time && <Fragment> {pr.time}</Fragment>}
                            {pr.final3F && <Fragment> 上{pr.final3F}</Fragment>}
                          </span>
                        ))}
                      </div>
                    )}
                    {h.training && (
                      <div class="rb-training">
                        🏋️ {h.training.trainingCourse || ''}{h.training.training3F || ''}
                        {h.training.training1F && <Fragment>1F{h.training.training1F}</Fragment>}
                        {h.training.trainingGrade && <Fragment> {h.training.trainingGrade}</Fragment>}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  )}

  <!-- ═══ 出馬表パネル ═══ -->
  {entriesData && (
    <div class="main-tab-panel" id="mainPanel-entries">
      <div class="tab-container">
        <!-- レースタブバー -->
        <div class="tab-bar" role="tablist" id="entriesTabBar">
          {entriesData.races.map((race, i) => (
            <button
              class={`tab-btn ${i === 0 ? 'active' : ''}`}
              role="tab"
              data-entries-tab={i}
            >
              {race.raceNumber}R
            </button>
          ))}
        </div>

        <!-- レースタブパネル -->
        {entriesData.races.map((race, i) => (
          <div
            class={`tab-panel ${i === 0 ? 'active' : ''}`}
            data-entries-panel={i}
          >
            <!-- レース情報 -->
            <div class="race-info-bar">
              <span class="race-num-badge">{race.raceNumber}R</span>
              <span class="race-name-text">{race.raceName || '　'}</span>
              <span class="race-chip">{race.surface}{race.distance}m</span>
              {race.startTime && <span class="race-chip">{race.startTime}発走</span>}
              <span class="race-chip">{race.headCount}頭</span>
            </div>

            <!-- 出馬表テーブル -->
            <div class="horse-table-wrap">
              <table class="horse-table entries-table">
                <thead>
                  <tr>
                    <th class="th-num">馬番</th>
                    <th class="th-name">馬名</th>
                    <th class="th-small">性齢</th>
                    <th class="th-small">斤量</th>
                    <th class="th-small">騎手</th>
                    <th class="th-small">調教師</th>
                    <th class="th-small">戦績</th>
                  </tr>
                </thead>
                <tbody>
                  {race.horses.map(horse => {
                    const rec = horse.record.total;
                    const totalRuns = rec.wins + rec.seconds + rec.thirds + rec.unplaced;
                    return (
                      <tr class="entries-row" data-horse-name={horse.name}>
                        <td class="td-num">{horse.number}</td>
                        <td class="td-name">
                          <span class="horse-name-main">{horse.name}</span>
                          <span class="horse-pedigree">{horse.sire} × {horse.bms}</span>
                        </td>
                        <td class="td-small">{horse.gender}{horse.age}</td>
                        <td class="td-small">{horse.weight ?? '—'}</td>
                        <td class="td-small">{horse.jockey}</td>
                        <td class="td-small">{horse.trainer}</td>
                        <td class="td-small">{totalRuns}戦{rec.wins}勝</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>

            <!-- 直近走 展開ブロック -->
            {race.horses.map(horse => (
              horse.recentRaces && horse.recentRaces.length > 0 && (
                <details class="recent-races-block">
                  <summary class="recent-summary">
                    <span class="recent-horse-num">{horse.number}</span>
                    <span class="recent-horse-name">{horse.name}</span>
                    <span class="recent-label">直近{Math.min(horse.recentRaces.length, 5)}走</span>
                  </summary>
                  <div class="recent-table-wrap">
                    <table class="recent-table">
                      <thead>
                        <tr>
                          <th>着順</th>
                          <th>日付</th>
                          <th>会場</th>
                          <th>距離</th>
                          <th>馬場</th>
                          <th>人気</th>
                          <th>通過順</th>
                          <th>上3F</th>
                          <th>タイム</th>
                          <th>騎手</th>
                        </tr>
                      </thead>
                      <tbody>
                        {horse.recentRaces.slice(0, 5).map(r => {
                          const rankText = r.finishStatus ? r.finishStatus : `${r.finish}`;
                          const rankClass = r.finish === 1 ? 'rank-1' : r.finish === 2 ? 'rank-2' : r.finish === 3 ? 'rank-3' : '';
                          return (
                            <tr>
                              <td class={`td-rank ${rankClass}`}>{rankText}</td>
                              <td class="td-date">{r.date.slice(5)}</td>
                              <td>{r.venue}</td>
                              <td>{r.distance}m</td>
                              <td>{r.trackCondition}</td>
                              <td>{r.popularity}人</td>
                              <td class="td-passing">{r.passingOrder || '—'}</td>
                              <td>{r.last3f || '—'}</td>
                              <td>{r.time || '—'}</td>
                              <td>{r.jockey}</td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>
                </details>
              )
            ))}
          </div>
        ))}
      </div>
    </div>
  )}
</BaseLayout>

<style>
/* ── 印・近走パネル ── */
.rb-race-card { margin-bottom: 1rem; border: 1px solid #334155; border-radius: 8px; overflow: hidden; }
.rb-race-header { background: #1e293b; padding: 0.6rem 1rem; display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
.rb-race-num { font-weight: 800; font-size: 1.1rem; }
.rb-race-name { font-weight: 600; }
.rb-race-dist, .rb-race-time, .rb-race-count { color: #94a3b8; font-size: 0.85rem; }
.rb-horse-list { display: flex; flex-direction: column; }
.rb-horse { padding: 0.5rem 0.75rem; border-bottom: 1px solid #1e293b; }
.rb-horse:last-child { border-bottom: none; }
.rb-honmei { border-left: 3px solid #ef4444; background: rgba(239,68,68,0.05); }
.rb-taikou { border-left: 3px solid #3b82f6; background: rgba(59,130,246,0.05); }
.rb-tanana { border-left: 3px solid #f59e0b; background: rgba(245,158,11,0.05); }
.rb-renka { border-left: 3px solid #64748b; }
.rb-hoseki { border-left: 3px solid #475569; }
.rb-horse-main { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
.rb-mark { font-weight: 800; font-size: 1.1rem; min-width: 1.3rem; text-align: center; }
.rb-mark-honmei { color: #ef4444; }
.rb-mark-taikou { color: #3b82f6; }
.rb-mark-tanana { color: #f59e0b; }
.rb-mark-renka { color: #94a3b8; }
.rb-mark-hoseki { color: #64748b; }
.rb-num { font-weight: 700; min-width: 1.5rem; text-align: center; }
.rb-name { font-weight: 600; }
.rb-info { color: #94a3b8; font-size: 0.8rem; }
.rb-trainer { color: #64748b; font-size: 0.75rem; }
.rb-score { font-size: 0.75rem; color: #f59e0b; font-weight: 600; margin-left: auto; }
.rb-marks-row { display: flex; gap: 2px; margin-top: 0.2rem; }
.rb-mark-chip { font-size: 0.85rem; min-width: 1.2em; text-align: center; }
.rb-past { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.3rem; }
.rb-past-item { font-size: 0.7rem; background: #1e293b; border-radius: 3px; padding: 1px 5px; color: #94a3b8; white-space: nowrap; }
