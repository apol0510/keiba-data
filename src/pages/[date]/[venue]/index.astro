<script>
// メインタブ切り替え（指数 / 出馬表）
document.getElementById('mainTabBar')?.addEventListener('click', (e) => {
  const btn = (e.target as HTMLElement).closest('.main-tab-btn') as HTMLElement | null;
  if (!btn) return;
  const tab = btn.dataset.mainTab;
  if (!tab) return;

  document.querySelectorAll('.main-tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  document.querySelectorAll('.main-tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById(`mainPanel-${tab}`)?.classList.add('active');
});

// コンピ指数レースタブ切り替え
const tabBar = document.getElementById('tabBar');
const panels = document.querySelectorAll<HTMLElement>('#mainPanel-index .tab-panel');
const tabs   = document.querySelectorAll<HTMLElement>('#tabBar .tab-btn');

tabBar?.addEventListener('click', (e) => {
  const btn = (e.target as HTMLElement).closest('.tab-btn') as HTMLElement | null;
  if (!btn) return;
  const idx = Number(btn.dataset.tab);

  tabs.forEach((t, i) => {
    t.classList.toggle('active', i === idx);
    t.setAttribute('aria-selected', i === idx ? 'true' : 'false');
  });
  panels.forEach((p, i) => {
    p.classList.toggle('active', i === idx);
  });
});

// 出馬表レースタブ切り替え
document.getElementById('entriesTabBar')?.addEventListener('click', (e) => {
  const btn = (e.target as HTMLElement).closest('.tab-btn') as HTMLElement | null;
  if (!btn) return;
  const idx = Number(btn.dataset.entriesTab);
  if (isNaN(idx)) return;

  document.querySelectorAll('#entriesTabBar .tab-btn').forEach((t, i) => {
    t.classList.toggle('active', i === idx);
  });
  document.querySelectorAll('[data-entries-panel]').forEach((p, i) => {
    (p as HTMLElement).classList.toggle('active', i === idx);
  });
});

// ソート切り替え（全テーブル一括）
let currentSort: 'number' | 'index' = 'number';

function sortAllTables(sort: 'number' | 'index') {
  document.querySelectorAll<HTMLElement>('.horse-tbody').forEach(tbody => {
    const rows = Array.from(tbody.querySelectorAll<HTMLElement>('tr'));
    rows.sort((a, b) => {
      const aVal = Number(sort === 'number' ? a.dataset.number : a.dataset.index);
      const bVal = Number(sort === 'number' ? b.dataset.number : b.dataset.index);
      return sort === 'number' ? aVal - bVal : bVal - aVal;
    });
    rows.forEach(r => tbody.appendChild(r));
  });
}

document.getElementById('sortToggle')?.addEventListener('click', (e) => {
  const btn = (e.target as HTMLElement).closest('.sort-btn') as HTMLElement | null;
  if (!btn || !btn.dataset.sort) return;
  const sort = btn.dataset.sort as 'number' | 'index';
  if (sort === currentSort) return;

  currentSort = sort;
  document.querySelectorAll('.sort-btn').forEach(b => {
    b.classList.toggle('active', b === btn);
  });
  sortAllTables(sort);
});
</script>
