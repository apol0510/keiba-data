---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { VENUES, getComputerDataUrl, type ComputerData, type ComputerHorse } from '../../../lib/venues';

const { date, venue: venueCode } = Astro.params;

if (!date || !/^\d{4}-\d{2}-\d{2}$/.test(date) || !venueCode) {
  return Astro.redirect('/');
}

const venueInfo = VENUES.find(v => v.code === venueCode.toUpperCase());
if (!venueInfo) {
  return Astro.redirect('/');
}

let data: ComputerData | null = null;
try {
  const url = getComputerDataUrl(date, venueInfo);
  const res = await fetch(url);
  if (res.ok) data = await res.json();
} catch (_) {}

const prev = new Date(date); prev.setDate(prev.getDate() - 1);
const next = new Date(date); next.setDate(next.getDate() + 1);
const fmt = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;

function formatDateJa(d: string): string {
  const [y, m, day] = d.split('-');
  return `${y}年${Number(m)}月${Number(day)}日（${['日','月','火','水','木','金','土'][new Date(d).getDay()]}）`;
}

// 印を付与（指数順で◎○▲△）
function getMark(rank: number): { mark: string; key: string } {
  if (rank === 0) return { mark: '◎', key: 'honmei' };
  if (rank === 1) return { mark: '○', key: 'taikou' };
  if (rank === 2) return { mark: '▲', key: 'tanana' };
  if (rank <= 9)  return { mark: '△', key: 'renshita' };
  return { mark: '', key: 'none' };
}

// 各レースに印と調整済み指数を付与
interface HorseWithMark extends ComputerHorse {
  mark: string;
  markKey: string;
  displayIndex: number; // -10した表示用
}

const races = data?.races.map(race => {
  const sorted = [...race.horses].sort((a, b) => b.computerIndex - a.computerIndex);
  // 34以下（displayIndex = computerIndex - 10 <= 34）を除外してrankを付与
  let markRank = 0;
  const horses: HorseWithMark[] = sorted.map((h) => {
    const displayIndex = h.computerIndex - 10;
    if (displayIndex <= 34) {
      return { ...h, mark: '', markKey: 'none', displayIndex };
    }
    const { mark, key } = getMark(markRank);
    markRank++;
    return { ...h, mark, markKey: key, displayIndex };
  });
  // 馬番順に並べ直して返す（表示は馬番順）
  const byNumber = [...horses].sort((a, b) => a.number - b.number);
  return { ...race, horses: byNumber };
}) ?? [];

const hasJockey  = races[0]?.horses[0]?.jockey   != null;
const hasWeight  = races[0]?.horses[0]?.weight    != null;
const hasAgeGend = races[0]?.horses[0]?.ageGender != null;

const title = `${venueInfo.name} ${formatDateJa(date)} コンピ指数`;
---

<BaseLayout title={title} description={`${formatDateJa(date)} ${venueInfo.name}のコンピ指数`}>
  <!-- パンくず -->
  <nav class="breadcrumb" aria-label="パンくず">
    <a href="/">今日</a>
    <span>›</span>
    <a href={`/${date}`}>{formatDateJa(date)}</a>
    <span>›</span>
    <span class="current">{venueInfo.name}</span>
  </nav>

  <!-- ヘッダー -->
  <header class="venue-hero">
    <div class="venue-hero-inner">
      <div class="venue-hero-left">
        <span class={`cat-pill cat-${venueInfo.category}`}>{venueInfo.categoryLabel}</span>
        <h1 class="venue-title">{venueInfo.name}競馬</h1>
        <p class="venue-date">{formatDateJa(date)}</p>
      </div>
      <div class="venue-hero-nav">
        <a class="nav-btn" href={`/${fmt(prev)}/${venueCode}`}>
          <span class="arrow">‹</span>
          <span class="label">{Number(fmt(prev).split('-')[2])}日</span>
        </a>
        <a class="nav-btn back-btn" href={`/${date}`}>一覧</a>
        <a class="nav-btn" href={`/${fmt(next)}/${venueCode}`}>
          <span class="label">{Number(fmt(next).split('-')[2])}日</span>
          <span class="arrow">›</span>
        </a>
      </div>
    </div>
  </header>

  <!-- 凡例 + ソートトグル -->
  <div class="legend">
    <span class="leg-item honmei">◎ 本命</span>
    <span class="leg-item taikou">○ 対抗</span>
    <span class="leg-item tanana">▲ 単穴</span>
    <span class="leg-item renshita">△ 連下</span>
    <div class="sort-toggle" id="sortToggle">
      <button class="sort-btn active" data-sort="number">馬番順</button>
      <button class="sort-btn" data-sort="index">指数順</button>
    </div>
  </div>

  {!data ? (
    <div class="empty-state">
      <div class="empty-icon">📭</div>
      <p>この日の{venueInfo.name}のデータはありません</p>
    </div>
  ) : (
    <div class="tab-container" id="tabContainer">
      <!-- タブバー -->
      <div class="tab-bar" role="tablist" id="tabBar">
        {races.map((race, i) => (
          <button
            class={`tab-btn ${i === 0 ? 'active' : ''}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-tab={i}
            aria-controls={`panel-${i}`}
          >
            {race.raceNumber}R
          </button>
        ))}
      </div>

      <!-- タブパネル -->
      {races.map((race, i) => {
        return (
          <div
            class={`tab-panel ${i === 0 ? 'active' : ''}`}
            role="tabpanel"
            id={`panel-${i}`}
            data-panel={i}
          >
            <!-- レース情報 -->
            <div class="race-info-bar">
              <span class="race-num-badge">{race.raceNumber}R</span>
              <span class="race-name-text">{race.raceName || '　'}</span>
              {race.distance && <span class="race-chip">{race.surface}{race.distance}m</span>}
              {race.startTime && <span class="race-chip">{race.startTime}発走</span>}
            </div>

            <!-- 全頭テーブル -->
            <div class="horse-table-wrap">
              <table class="horse-table">
                <thead>
                  <tr>
                    <th class="th-mark">印</th>
                    <th class="th-num">馬番</th>
                    <th class="th-name">馬名</th>
                    <th class="th-idx">指数</th>
                    {hasJockey  && <th class="th-small">騎手</th>}
                    {hasWeight  && <th class="th-small">斤量</th>}
                    {hasAgeGend && <th class="th-small">馬齢</th>}
                  </tr>
                </thead>
                <tbody class="horse-tbody">
                  {race.horses.map(horse => (
                    <tr
                      class={`row-${horse.markKey}`}
                      data-number={horse.number}
                      data-index={horse.computerIndex}
                    >
                      <td class="td-mark">
                        {horse.mark && (
                          <span class={`mark-pill ${horse.markKey}`}>{horse.mark}</span>
                        )}
                      </td>
                      <td class="td-num">{horse.number}</td>
                      <td class="td-name">{horse.name}</td>
                      <td class="td-idx">
                        <span class={`idx-val ${horse.markKey}`}>{horse.displayIndex}</span>
                      </td>
                      {hasJockey  && <td class="td-small">{horse.jockey  ?? '—'}</td>}
                      {hasWeight  && <td class="td-small">{horse.weight  ?? '—'}</td>}
                      {hasAgeGend && <td class="td-small">{horse.ageGender ?? '—'}</td>}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        );
      })}
    </div>
  )}
</BaseLayout>

<style>
/* ── パンくず ── */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.82rem;
  color: #9ca3af;
  margin-bottom: 1rem;
  flex-wrap: wrap;

  a { color: #9ca3af; &:hover { color: #fff; text-decoration: none; } }
  .current { color: #e5e7eb; }
}

/* ── ヒーローヘッダー ── */
.venue-hero {
  background: linear-gradient(135deg, #1e1b4b 0%, #312e81 40%, #4c1d95 100%);
  border-radius: 16px;
  padding: 1.5rem;
  margin-bottom: 1rem;
  border: 1px solid rgba(139,92,246,0.3);
  box-shadow: 0 4px 24px rgba(124,58,237,0.2);
}

.venue-hero-inner {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}

.cat-pill {
  display: inline-block;
  padding: 0.15rem 0.6rem;
  border-radius: 99px;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  margin-bottom: 0.4rem;

  &.cat-jra    { background: rgba(96,165,250,0.25); color: #93c5fd; border: 1px solid rgba(96,165,250,0.4); }
  &.cat-nankan { background: rgba(251,146,60,0.25); color: #fdba74; border: 1px solid rgba(251,146,60,0.4); }
  &.cat-local  { background: rgba(52,211,153,0.25); color: #6ee7b7; border: 1px solid rgba(52,211,153,0.4); }
}

.venue-title {
  font-size: 2rem;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.venue-date {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.6);
  margin-top: 0.3rem;
}

.venue-hero-nav {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.nav-btn {
  display: flex;
  align-items: center;
  gap: 0.2rem;
  padding: 0.4rem 0.9rem;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 8px;
  color: rgba(255,255,255,0.85);
  font-size: 0.85rem;
  font-weight: 500;
  text-decoration: none;
  transition: background 0.15s;

  &:hover { background: rgba(255,255,255,0.2); text-decoration: none; color: #fff; }

  .arrow { font-size: 1.1rem; line-height: 1; }
}

.back-btn {
  font-size: 0.8rem;
  padding: 0.4rem 0.75rem;
}

/* ── 凡例 ── */
.legend {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.6rem 1rem;
  background: rgba(255,255,255,0.04);
  border-radius: 8px;
  margin-bottom: 1rem;
  flex-wrap: wrap;
  border: 1px solid rgba(255,255,255,0.07);
}

.leg-item {
  font-size: 0.85rem;
  font-weight: 600;

  &.honmei { color: #f59e0b; }
  &.taikou { color: #34d399; }
  &.tanana { color: #60a5fa; }
  &.renshita  { color: #c084fc; }
}

.sort-toggle {
  display: flex;
  gap: 0.25rem;
  margin-left: auto;
}

.sort-btn {
  padding: 0.25rem 0.7rem;
  border-radius: 6px;
  border: 1px solid rgba(255,255,255,0.12);
  background: transparent;
  color: #6b7280;
  font-size: 0.78rem;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.15s;

  &:hover { color: #e5e7eb; background: rgba(255,255,255,0.06); }

  &.active {
    background: rgba(124,58,237,0.25);
    border-color: rgba(124,58,237,0.5);
    color: #c4b5fd;
  }
}

/* ── タブバー ── */
.tab-container { margin-top: 0; }

.tab-bar {
  display: flex;
  gap: 0.3rem;
  overflow-x: auto;
  padding-bottom: 0.2rem;
  margin-bottom: 1rem;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.1) transparent;
}

.tab-btn {
  flex-shrink: 0;
  padding: 0.4rem 0.85rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  color: #9ca3af;
  font-size: 0.88rem;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.15s;

  &:hover { background: rgba(255,255,255,0.1); color: #e5e7eb; }

  &.active {
    background: linear-gradient(135deg, #7c3aed, #5b21b6);
    border-color: #7c3aed;
    color: #fff;
    box-shadow: 0 2px 8px rgba(124,58,237,0.4);
  }
}

/* ── タブパネル ── */
.tab-panel {
  display: none;
  &.active { display: block; }
}

/* ── レース情報バー ── */
.race-info-bar {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}

.race-num-badge {
  background: linear-gradient(135deg, #7c3aed, #5b21b6);
  color: #fff;
  font-weight: 800;
  font-size: 1rem;
  padding: 0.25rem 0.7rem;
  border-radius: 8px;
}

.race-name-text {
  font-weight: 600;
  font-size: 0.95rem;
  color: #e5e7eb;
}

.race-chip {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 6px;
  padding: 0.15rem 0.5rem;
  font-size: 0.78rem;
  color: #9ca3af;
}

/* ── テーブル ── */
.horse-table-wrap {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
}

.horse-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;

  thead tr {
    background: rgba(255,255,255,0.05);
  }

  th {
    padding: 0.5rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #6b7280;
    text-align: left;
    letter-spacing: 0.04em;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  tbody tr {
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.1s;

    &:last-child { border-bottom: none; }
    &:hover { background: rgba(255,255,255,0.04); }

    &.row-honmei { background: rgba(245,158,11,0.06); }
    &.row-taikou { background: rgba(52,211,153,0.05); }
    &.row-tanana { background: rgba(96,165,250,0.05); }
    &.row-renshita  { background: rgba(192,132,252,0.04); }
  }

  td { padding: 0.5rem 0.75rem; }
}

.th-mark { width: 2.5rem; }
.th-num  { width: 3.5rem; }
.th-idx  { width: 4rem; }
.th-small { width: 5rem; }

.td-mark { text-align: center; }
.td-num  { color: #6b7280; font-size: 0.85rem; }
.td-name { font-weight: 600; color: #f3f4f6; }
.td-small { font-size: 0.82rem; color: #9ca3af; }

.mark-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.6rem;
  height: 1.6rem;
  border-radius: 6px;
  font-weight: 800;
  font-size: 0.9rem;

  &.honmei { background: rgba(245,158,11,0.2);  color: #fbbf24; }
  &.taikou { background: rgba(52,211,153,0.2);  color: #34d399; }
  &.tanana { background: rgba(96,165,250,0.2);  color: #60a5fa; }
  &.renshita  { background: rgba(192,132,252,0.2); color: #c084fc; }
}

.idx-val {
  font-weight: 700;
  font-size: 0.95rem;

  &.honmei { color: #fbbf24; }
  &.taikou { color: #34d399; }
  &.tanana { color: #60a5fa; }
  &.renshita  { color: #c084fc; }
  &.none   { color: #6b7280; }
}

/* ── 空状態 ── */
.empty-state {
  text-align: center;
  padding: 4rem 1rem;
  color: #6b7280;
  .empty-icon { font-size: 3rem; margin-bottom: 1rem; }
}

/* ── スマホ ── */
@media (max-width: 640px) {
  .venue-title { font-size: 1.5rem; }
  .venue-hero-nav { width: 100%; justify-content: flex-end; }
  .horse-table { font-size: 0.82rem; }
  .horse-table th, .horse-table td { padding: 0.4rem 0.5rem; }
  .mc-name { font-size: 0.9rem; }
  .leg-note { display: none; }
}
</style>

<script>
// タブ切り替え
const tabBar = document.getElementById('tabBar');
const panels = document.querySelectorAll<HTMLElement>('.tab-panel');
const tabs   = document.querySelectorAll<HTMLElement>('.tab-btn');

tabBar?.addEventListener('click', (e) => {
  const btn = (e.target as HTMLElement).closest('.tab-btn') as HTMLElement | null;
  if (!btn) return;
  const idx = Number(btn.dataset.tab);

  tabs.forEach((t, i) => {
    t.classList.toggle('active', i === idx);
    t.setAttribute('aria-selected', i === idx ? 'true' : 'false');
  });
  panels.forEach((p, i) => {
    p.classList.toggle('active', i === idx);
  });
});

// ソート切り替え（全テーブル一括）
let currentSort: 'number' | 'index' = 'number';

function sortAllTables(sort: 'number' | 'index') {
  // テーブルをソート
  document.querySelectorAll<HTMLElement>('.horse-tbody').forEach(tbody => {
    const rows = Array.from(tbody.querySelectorAll<HTMLElement>('tr'));
    rows.sort((a, b) => {
      const aVal = Number(sort === 'number' ? a.dataset.number : a.dataset.index);
      const bVal = Number(sort === 'number' ? b.dataset.number : b.dataset.index);
      return sort === 'number' ? aVal - bVal : bVal - aVal; // 指数は降順
    });
    rows.forEach(r => tbody.appendChild(r));
  });

}

document.getElementById('sortToggle')?.addEventListener('click', (e) => {
  const btn = (e.target as HTMLElement).closest('.sort-btn') as HTMLElement | null;
  if (!btn || !btn.dataset.sort) return;
  const sort = btn.dataset.sort as 'number' | 'index';
  if (sort === currentSort) return;

  currentSort = sort;
  document.querySelectorAll('.sort-btn').forEach(b => {
    b.classList.toggle('active', b === btn);
  });
  sortAllTables(sort);
});
</script>
