---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = '地方競馬・JRA・南関 全24競馬場のコンピ指数を公開'
} = Astro.props;

const siteTitle = title === 'コンピ指数' ? title : `${title} | コンピ指数`;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="generator" content={Astro.generator}>
  <title>{siteTitle}</title>
  <meta name="description" content={description}>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style is:global>
    @import '../styles/global.scss';
  </style>
</head>
<body>
  <nav class="main-nav">
    <div class="container">
      <div class="nav-content">
        <a href="/" class="logo">
          <span class="logo-icon">📊</span>
          <span class="logo-text">コンピ指数</span>
        </a>
        <div class="nav-links">
          <a href="/">今日の開催</a>
          <a href="https://keiba-intelligence.netlify.app" target="_blank" rel="noopener" class="nav-cta">
            買い目を見る →
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="main-footer">
    <div class="container">
      <div class="footer-cta">
        <p class="footer-cta-text"><strong>中央・南関競馬</strong>の買い目・AI予想はこちら</p>
        <a href="https://keiba-intelligence.netlify.app" target="_blank" rel="noopener" class="footer-cta-btn">
          keiba-intelligence で買い目を確認 →
        </a>
      </div>
      <p class="footer-copy">コンピ指数 - 地方・JRA・南関 全24競馬場対応</p>
    </div>
  </footer>
</body>
</html>
